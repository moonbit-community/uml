@startuml
title Online Order Processing

actor "Customer" as customer #gold
boundary "Web Gateway" as gateway #lightblue
control "Order Service" as service #lime
entity "Inventory DB" as inventory #salmon
database "Payment Gateway" as payment #lightcoral
queue "Notification Queue" as notify #lavender
collections "Cache Layer" as cache #palegreen

box #lightyellow Frontend
participant "CDN" as cdn
end box

box #lightgrey Backend
participant "Worker Pool" as worker
participant "Audit Logger" as audit
end box

autonumber 1 1 "(#)"

== Order Placement ==

& {browse} customer -> gateway : Browse products
gateway --> cache : Check cache
alt #lightgreen cache hit
  cache -->> gateway : Return cached data
else cache miss
  gateway -> service ++ #lightcyan : Fetch product list
  service -> inventory : Query stock
  inventory -->> service -- : Product data
  service --> gateway -- : Formatted results
end
gateway --> customer : Display products

customer -> gateway : Add to cart
gateway -> service ++ : Add item

note right of service #yellow : validate stock
service -> inventory : Reserve item
alt #palegreen reserved
  inventory -->> service : OK
  service --> gateway -- : Cart updated
else out of stock
  inventory --> service : Failed
  service --> gateway -- : Error message
  gateway --> customer : "Out of stock"
  destroy gateway
end

gateway --> customer : Cart confirmed

== Checkout Process ==

customer -> gateway : Checkout
gateway -> service ++ : Create order
service -> inventory ++ : Reduce stock
inventory -->> service -- : Stock reduced

note across : Payment processing may take up to 30 seconds

service -> payment ++ -- : Charge $49.99
autonumber stop
payment --> service : Payment confirmed
autonumber resume

par #lightcyan Payment and Notification
  & service -> inventory : Finalize order
  & service -> notify : Send confirmation
  & service -> audit : Log transaction
end

service --> gateway -- : Order #1234 created
gateway --> customer : "Order confirmed"

hnote over service, inventory, notify #aliceblue : Transaction complete

== Post-Processing ==

... waiting for fulfillment ...

ref over service, inventory : Fulfillment system
worker -> service : Pick order
worker -> inventory : Update tracking

note right : Shipment dispatched

service -> notify : Send tracking
notify -->> customer : Tracking email

loop #lightyellow every 30 min
  service -> inventory : Check status
  inventory -->> service : Pending
  ... timeout ...
end

break #mistyrose on cancel
  service -> inventory : Cancel reservation
  destroy inventory
  return refund
end

customer -> service : Request support
& customer -> audit : Create ticket
audit -->> customer : Ticket created

{anchor1} <-> {anchor2} : linked

@enduml
